# ==========================================
# Djblog 环境变量配置示例
# ==========================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 根据实际环境修改下面的值
# 3. 不要将 .env 文件提交到 Git
# ==========================================

# ------------------------------------------
# Docker 镜像配置
# ------------------------------------------
DOCKER_REGISTRY=docker.io
IMAGE_PREFIX=djblog
VERSION=latest

# ------------------------------------------
# Spring 环境配置
# ------------------------------------------
# 可选值：dev（开发）, test（测试）, prod（生产）
SPRING_PROFILES_ACTIVE=dev

# ------------------------------------------
# 数据库配置
# ------------------------------------------
DB_HOST=mysql
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_secure_database_password_here

# ------------------------------------------
# Redis 配置
# ------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password_here

# ------------------------------------------
# JWT 配置（生产环境必须设置，至少 64 字符）
# ------------------------------------------
# 生成随机密钥示例：openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-must-be-at-least-64-characters-long-for-hs512-algorithm-security

# ------------------------------------------
# AI 配置（可选，用于评论审核）
# ------------------------------------------
# 阿里云 DashScope API Key
AI_DASHSCOPE_API_KEY=
